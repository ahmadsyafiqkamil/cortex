# Copy to .env and fill in. .env is gitignored — never commit real keys.

# --- LLM (provider-agnostic, OpenAI-compatible) ---
# Point LLM_BASE_URL at any provider's OpenAI-compatible endpoint.
#   MiniMax (international): https://api.minimaxi.chat/v1   (verify in MiniMax docs)
#   OpenAI:                  https://api.openai.com/v1
#   Local (e.g. Ollama):     http://host.docker.internal:11434/v1
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# Some providers (e.g. certain MiniMax endpoints) also require a group id.
# Leave blank if not needed.
LLM_GROUP_ID=

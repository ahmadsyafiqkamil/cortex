---
pagination:
  data: pages
  size: 1
  alias: page
permalink: "/{{ page.slug }}/"
layout: layout.njk
---

{% set pageSlug = page.slug %}
{% set pageDisputes = disputes | selectattr('page', 'equalto', pageSlug) | list %}
{% set openDisputes = pageDisputes | selectattr('status', 'equalto', 0) | list %}

<div class="mb-6">
  <a href="/" class="text-sm text-blue-400 hover:text-blue-300 transition-colors">&larr; Back to index</a>
</div>

<article>
  <header class="mb-6 pb-4 border-b border-gray-800">
    <h1 class="text-3xl font-bold mb-2">{{ page.title }}</h1>
    <p class="text-sm text-gray-500 font-mono">[[{{ page.slug }}]]</p>

    <div class="flex flex-wrap items-center gap-2 mt-3">
      {% for tag in page.tags %}
      <span class="px-2 py-0.5 text-xs bg-gray-800 text-gray-400 rounded-full">{{ tag }}</span>
      {% endfor %}
    </div>

    {% if openDisputes | length > 0 %}
    <div class="mt-4 p-3 bg-red-900/20 border border-red-800/50 rounded-lg">
      <span class="text-sm text-red-400 font-semibold">
        &#9888; {{ openDisputes | length }} open dispute(s) on this page
      </span>
    </div>
    {% endif %}
  </header>

  <div class="prose prose-invert max-w-none mb-8 text-gray-200 leading-relaxed">
    {{ page.contentHtml | safe }}
  </div>

  <div class="border-t border-gray-800 pt-6 mt-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-sm">
      <div class="p-3 bg-gray-900 border border-gray-800 rounded-lg">
        <span class="text-gray-500">Latest Blob</span>
        <code class="block text-xs text-blue-400 mt-1 break-all">{{ page.latestBlob }}</code>
      </div>
      <div class="p-3 bg-gray-900 border border-gray-800 rounded-lg">
        <span class="text-gray-500">Versions</span>
        <span class="block text-lg font-mono text-gray-200">{{ page.totalHistory }}</span>
      </div>
      <div class="p-3 bg-gray-900 border border-gray-800 rounded-lg">
        <span class="text-gray-500">Sources Cited</span>
        <span class="block text-lg font-mono text-gray-200">{{ page.rawMarkers | unique | list | length }}</span>
      </div>
    </div>
  </div>

  {% if page.wikilinks | length > 0 %}
  <div class="mt-6">
    <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">Linked Pages</h3>
    <div class="flex flex-wrap gap-1.5">
    {% for link in page.wikilinks %}
      <a href="/{{ link }}/" class="px-2.5 py-1 text-xs bg-blue-900/30 text-blue-300 border border-blue-800/50 rounded hover:bg-blue-800/40 transition-colors">
        [[{{ link }}]]
      </a>
    {% endfor %}
    </div>
  </div>
  {% endif %}

  {% if page.sourceEntries | length > 0 %}
  <div class="mt-6">
    <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">Sources (frontmatter)</h3>
    <div class="space-y-1.5">
    {% for src in page.sourceEntries %}
      <div class="flex items-center gap-2 text-xs">
        <span class="text-gray-400">{{ src.title or src.blob }}</span>
        <a href="https://aggregator.walrus-testnet.walrus.space/v1/blobs/{{ src.blob }}" target="_blank" rel="noopener"
           class="font-mono text-blue-400 hover:text-blue-300 ml-auto">blob:{{ src.blob | truncate(12) }}...</a>
      </div>
    {% endfor %}
    </div>
  </div>
  {% endif %}

  {% if page.claims | length > 0 %}
  <div class="mt-6">
    <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">Confidence Scores</h3>
    <p class="text-xs text-gray-600 mb-3">Per claim = count of unique source markers. 2+ sources = high confidence.</p>
    <div class="space-y-2">
    {% for claim in page.claims %}
      <div class="p-2.5 bg-gray-900 border border-gray-800 rounded-lg flex items-start justify-between gap-3">
        <span class="text-xs text-gray-300">{{ claim.text }}</span>
        <span class="shrink-0 px-2 py-0.5 text-xs font-mono rounded border {% if claim.confidence == 'high' %}bg-emerald-900/40 text-emerald-300 border-emerald-700/50{% else %}bg-yellow-900/30 text-yellow-400 border-yellow-700/50{% endif %}">
          {{ claim.uniqueMarkers }} source{% if claim.uniqueMarkers > 1 %}s{% endif %}
        </span>
      </div>
    {% endfor %}
    </div>
  </div>
  {% endif %}

  {% if pageDisputes | length > 0 %}
  <div class="mt-8">
    <h2 class="text-xl font-bold mb-4 text-red-400">Disputes ({{ pageDisputes | length }})</h2>
    {% for d in pageDisputes %}
    <div class="p-4 bg-red-900/10 border border-red-800/30 rounded-lg mb-3">
      <div class="flex items-start justify-between gap-3">
        <div>
          <span class="px-2 py-0.5 text-xs font-semibold {% if d.status == 0 %}bg-red-900/60 text-red-300{% elif d.status == 1 %}bg-emerald-900/60 text-emerald-300{% else %}bg-gray-800 text-gray-400{% endif %} rounded">
            {{ d.statusLabel }}
          </span>
        </div>
        <a href="{{ d.explorerUrl }}" target="_blank" rel="noopener"
           class="text-xs text-gray-500 hover:text-gray-300 font-mono">
          {{ d.disputeId | truncate(14) }}... &nearr;
        </a>
      </div>
      <p class="text-xs text-gray-500 mt-2">
        Raised by <code class="font-mono">{{ d.raisedBy | truncate(18) }}...</code>
      </p>
      {% if d.reasonBlob %}
      <p class="text-xs text-gray-600 mt-1 font-mono">Rationale blob: {{ d.reasonBlob }}</p>
      {% endif %}
      {% if d.rationaleHtml %}
      <div class="mt-3 p-3 bg-gray-900/50 border border-gray-800 rounded text-xs text-gray-400">
        {{ d.rationaleHtml | safe }}
      </div>
      {% endif %}
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {% if page.history | length > 0 %}
  <div class="mt-8" id="diff-wrapper">
    <h2 class="text-xl font-bold mb-4 text-gray-200">Version History (Time Travel)</h2>
    <p class="text-xs text-gray-600 mb-4">Compare any two versions side-by-side. Select two blob IDs to see the diff.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
      <div>
        <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Version A (baseline)</label>
        <select id="diff-select-a" class="w-full mt-1 px-3 py-2 bg-gray-900 border border-gray-700 rounded text-sm text-gray-200 focus:border-blue-600 focus:outline-none">
          <option value="{{ page.latestBlob }}">Current — {{ page.latestBlob | truncate(24) }}...</option>
          {% for blob in page.history | reverse %}
          <option value="{{ blob }}">Version {{ loop.revindex }} — {{ blob | truncate(24) }}...</option>
          {% endfor %}
        </select>
      </div>
      <div>
        <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Version B (compare)</label>
        <select id="diff-select-b" class="w-full mt-1 px-3 py-2 bg-gray-900 border border-gray-700 rounded text-sm text-gray-200 focus:border-blue-600 focus:outline-none">
          <option value="">— Select —</option>
          <option value="{{ page.latestBlob }}">Current — {{ page.latestBlob | truncate(24) }}...</option>
          {% for blob in page.history | reverse %}
          <option value="{{ blob }}">Version {{ loop.revindex }} — {{ blob | truncate(24) }}...</option>
          {% endfor %}
        </select>
      </div>
    </div>

    <button id="diff-btn" class="px-4 py-2 text-sm bg-blue-700 text-white rounded hover:bg-blue-600 transition-colors disabled:opacity-40">
      Compare Versions
    </button>

    <div id="diff-loading" class="hidden mt-4 text-sm text-gray-500">Fetching blobs &amp; computing diff...</div>
    <div id="diff-output" class="mt-4 p-4 bg-gray-900 border border-gray-800 rounded-lg text-sm font-mono overflow-x-auto max-h-[600px] overflow-y-auto"></div>
  </div>
  <script src="/assets/diff.js"></script>
  {% endif %}

  {% if page.history | length > 0 %}
  <div class="mt-6">
    <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">All Versions ({{ page.totalHistory }})</h3>
    <ol class="space-y-1">
      <li class="flex items-center gap-2 text-xs">
        <span class="text-emerald-400 font-semibold">latest</span>
        <code class="font-mono text-blue-400">{{ page.latestBlob }}</code>
        <a href="https://aggregator.walrus-testnet.walrus.space/v1/blobs/{{ page.latestBlob }}" target="_blank" rel="noopener"
           class="text-gray-500 hover:text-gray-300 text-xs">&nearr;</a>
      </li>
      {% for blob in page.history | reverse %}
      <li class="flex items-center gap-2 text-xs">
        <span class="text-gray-600 w-12 text-right">v{{ loop.revindex }}</span>
        <code class="font-mono text-gray-500">{{ blob }}</code>
        <a href="https://aggregator.walrus-testnet.walrus.space/v1/blobs/{{ blob }}" target="_blank" rel="noopener"
           class="text-gray-600 hover:text-gray-400 text-xs">&nearr;</a>
      </li>
      {% endfor %}
    </ol>
  </div>
  {% endif %}

  <div class="mt-8 pt-4 border-t border-gray-800 text-xs text-gray-600 space-y-1">
    <p>On-chain: <a href="https://suiscan.xyz/testnet/object/{{ config.wikiId }}" target="_blank" rel="noopener" class="text-blue-500 hover:text-blue-400 font-mono">{{ config.wikiId | truncate(20) }}... &nearr;</a></p>
    <p>Last updated by <code class="font-mono">{{ page.updatedBy }}</code></p>
    <p>Raw blob: <a href="https://aggregator.walrus-testnet.walrus.space/v1/blobs/{{ page.latestBlob }}" target="_blank" rel="noopener" class="text-blue-500 hover:text-blue-400 font-mono break-all">{{ page.latestBlob }}</a></p>
  </div>
</article>

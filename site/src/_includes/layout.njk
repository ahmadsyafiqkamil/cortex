<!DOCTYPE html>
<html lang="en" class="bg-gray-950 text-gray-100">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} — {% endif %}Cortex Wiki</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            gray: { 900: '#111827', 950: '#030712' }
          }
        }
      }
    }
  </script>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 32 32%22><text y=%2224%22 font-size=%2224%22>🧠</text></svg>">
</head>
<body class="min-h-screen flex flex-col">
  <nav class="border-b border-gray-800 bg-gray-900/70 backdrop-blur sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
      <a href="/" class="text-lg font-bold text-blue-400 hover:text-blue-300 transition-colors">
        Cortex Wiki
      </a>
      <div class="flex items-center gap-4 text-sm">
        <a href="/" class="text-gray-400 hover:text-white transition-colors">Pages</a>
        <a href="/sources/index.html" class="text-gray-400 hover:text-white transition-colors">Sources</a>
        <a href="/graph/index.html" class="text-gray-400 hover:text-white transition-colors">Graph</a>
        <a href="{{ config.wikiExplorerUrl }}" target="_blank" rel="noopener" class="text-gray-500 hover:text-gray-300 transition-colors text-xs">
          Explorer &nearr;
        </a>
      </div>
    </div>
  </nav>

  <main class="flex-1 max-w-6xl mx-auto px-4 py-8 w-full">
    {{ content | safe }}
  </main>

  <footer class="border-t border-gray-800 py-4 text-center text-xs text-gray-600">
    <p>
      Cortex — Verifiable provenance on
      <a href="https://wal.app" target="_blank" rel="noopener" class="text-gray-500 hover:text-gray-400">Walrus</a>
      &amp;
      <a href="https://sui.io" target="_blank" rel="noopener" class="text-gray-500 hover:text-gray-400">Sui</a>.
      Package:
      <a href="https://suiscan.xyz/testnet/object/{{ config.packageId }}" target="_blank" rel="noopener" class="text-gray-500 hover:text-gray-400 font-mono">{{ config.packageId.slice(0,12) }}...</a>
    </p>
  </footer>
</body>
</html>

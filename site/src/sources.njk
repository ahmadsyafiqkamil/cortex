---
layout: layout.njk
permalink: /sources/
title: Registered Sources
---

<div class="mb-8">
  <h1 class="text-3xl font-bold mb-2">Registered Sources</h1>
  <p class="text-gray-400">{{ sources.length }} source(s) registered on-chain</p>
</div>

{% if sources | length == 0 %}
<div class="text-center py-16 text-gray-500">
  <p class="text-lg">No sources registered.</p>
</div>
{% else %}
<div class="grid gap-3">
{% for src in sources %}
  <div class="p-4 bg-gray-900 border border-gray-800 rounded-lg">
    <div class="flex items-start justify-between gap-3">
      <div class="min-w-0">
        <h2 class="font-semibold text-gray-200">{{ src.title }}</h2>
        <p class="text-xs text-gray-500 font-mono mt-1 break-all">blob: {{ src.blob }}</p>
        {% if src.originUrl %}
        <p class="text-xs text-gray-600 mt-0.5">{{ src.originUrl }}</p>
        {% endif %}
      </div>
      <div class="flex items-center gap-2 shrink-0">
        <a href="{{ src.aggregatorUrl }}" target="_blank" rel="noopener"
           class="px-2.5 py-1 text-xs bg-blue-900/40 text-blue-300 border border-blue-700/50 rounded hover:bg-blue-800/50 transition-colors">
          View Source
        </a>
      </div>
    </div>
    <div class="mt-2 text-xs text-gray-600 flex items-center gap-3">
      <span>Added by <code class="font-mono">{{ src.addedBy | truncate(14) }}</code></span>
    </div>
  </div>
{% endfor %}
</div>
{% endif %}

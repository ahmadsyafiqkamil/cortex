---
layout: layout.njk
title: Cortex Wiki
---

<div class="mb-8">
  <h1 class="text-3xl font-bold mb-2">Cortex Wiki</h1>
  <p class="text-gray-400">
    Decentralized knowledge base — {{ pages.length }} pages &middot;
    {{ sources.length }} sources &middot;
    {{ disputes.length }} disputes
  </p>
</div>

{% if disputes | length > 0 %}
<div class="mb-6 p-3 bg-red-900/20 border border-red-800/50 rounded-lg">
  <span class="text-sm text-red-400 font-semibold">&#9888; {{ disputes | selectattr('status', 'equalto', 0) | list | length }} open dispute(s)</span>
</div>
{% endif %}

<div class="grid gap-3">
{% for page in pages %}
  <a href="/{{ page.slug }}/index.html"
     class="block p-4 bg-gray-900 border border-gray-800 rounded-lg hover:border-blue-700 hover:bg-gray-800/70 transition-all group">
    <div class="flex items-start justify-between gap-3">
      <div class="min-w-0">
        <h2 class="text-lg font-semibold text-blue-400 group-hover:text-blue-300 transition-colors truncate">
          {{ page.title }}
        </h2>
        <p class="text-sm text-gray-500 font-mono mt-0.5">[[{{ page.slug }}]]</p>
        <div class="flex items-center gap-3 mt-2 text-xs text-gray-500">
          <span>{{ page.wikilinks | length }} link(s)</span>
          <span>{{ page.rawMarkers | unique | list | length }} source(s)</span>
          <span>{{ page.history | length }} version(s)</span>
        </div>
      </div>
      <div class="flex flex-col items-end gap-1.5 shrink-0">
        {% set pageSlug = page.slug %}
        {% set pageDisputes = disputes | selectattr('page', 'equalto', pageSlug) | list %}
        {% if pageDisputes | length > 0 %}
          <span class="px-2 py-0.5 text-xs font-semibold bg-red-900/60 text-red-300 border border-red-700/50 rounded">
            &#9888; DISPUTED
          </span>
        {% endif %}
        {% for claim in page.claims %}
          {% if claim.confidence == "high" %}
            <span class="px-2 py-0.5 text-xs font-mono bg-emerald-900/40 text-emerald-300 border border-emerald-700/50 rounded" title="{{ claim.uniqueMarkers }} source(s)">
              {{ claim.uniqueMarkers }}&#10003;
            </span>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </a>
{% endfor %}
</div>

{% if pages | length == 0 %}
<div class="text-center py-16 text-gray-500">
  <p class="text-lg">No pages yet.</p>
  <p class="text-sm mt-2">Run <code class="px-1.5 py-0.5 bg-gray-800 rounded font-mono text-xs">cortex ingest &lt;source&gt;</code> to populate the wiki.</p>
</div>
{% endif %}
